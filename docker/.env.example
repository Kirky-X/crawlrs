# =============================================================================
# Crawlrs 环境变量配置
# =============================================================================
# 复制此文件为 .env 并根据需要修改配置
# =============================================================================

# =============================================================================
# 应用基础配置
# =============================================================================
ENV_MODE=docker
RUST_LOG=info

# =============================================================================
# 应用端口配置
# =============================================================================
APP_PORT=3000

# =============================================================================
# 数据库配置
# =============================================================================
DB_HOST=db
DB_PORT=5432
DB_USER=crawlrs
DB_PASSWORD=password
DB_NAME=crawlrs
DATABASE_MAX_CONNECTIONS=20

# =============================================================================
# Redis配置
# =============================================================================
REDIS_HOST=redis
REDIS_PORT=6379

# =============================================================================
# 搜索引擎启用配置
# =============================================================================
SEARCH_ENGINE_GOOGLE_ENABLED=false
SEARCH_ENGINE_BING_ENABLED=true
SEARCH_ENGINE_BAIDU_ENABLED=true
SEARCH_ENGINE_SOGOU_ENABLED=true
SEARCH_ENGINE_DEFAULT=baidu

# =============================================================================
# Google搜索配置 (仅当SEARCH_ENGINE_GOOGLE_ENABLED=true时需要)
# =============================================================================
# 方式一: 使用Google Custom Search API (推荐)
# GOOGLE_SEARCH_API_KEY=your_google_api_key
# GOOGLE_SEARCH_CX=your_search_engine_id

# 方式二: 使用FlareSolverr代理 (需要启动flaresolverr和chrome服务)
# FLARESOLVERR_AUTO_START=true (当Google启用时自动启动FlareSolverr)

# =============================================================================
# FlareSolverr配置 (用于Google搜索代理)
# =============================================================================
FLARESOLVERR_HOST=flaresolverr
FLARESOLVERR_PORT=8191
FLARESOLVERR_AUTO_START=true
FLARESOLVERR_LOG_LEVEL=info
FLARESOLVERR_CAPTCHA_SOLVER=none

# =============================================================================
# Chrome配置 (用于FlareSolverr)
# =============================================================================
CHROME_HOST=chrome
CHROME_PORT=9222

# =============================================================================
# 速率限制配置
# =============================================================================
RATE_LIMITING_ENABLED=false
RATE_LIMITING_DEFAULT_RPM=60

# =============================================================================
# 并发配置
# =============================================================================
CONCURRENCY_DEFAULT_TEAM_LIMIT=10
CONCURRENCY_TASK_LOCK_DURATION=300

# =============================================================================
# 监控配置
# =============================================================================
METRICS_ENABLED=true
METRICS_PORT=3001
PROMETHEUS_PORT=9090

# =============================================================================
# 监控工具密码
# =============================================================================
GRAFANA_PASSWORD=admin
PGADMIN_PASSWORD=admin

# =============================================================================
# 数据卷路径配置
# =============================================================================
DATA_VOLUME_PATH=./data

# =============================================================================
# LLM配置 (可选)
# =============================================================================
# LLM_API_KEY=your_openai_api_key
# LLM_MODEL=gpt-3.5-turbo
# LLM_API_BASE_URL=https://api.openai.com/v1

# =============================================================================
# 使用说明
# =============================================================================
#
# 1. 复制此文件为 .env
# 2. 根据需要修改配置
# 3. 运行 docker-compose up -d 启动所有服务
#
# 快速启动命令:
#   全部启动:     docker-compose up -d
#   仅基础设施:   docker-compose --profile infrastructure up -d
#   仅应用:       docker-compose --profile app up -d
#   启动监控:     docker-compose --profile monitoring up -d
#
# 搜索引擎启用示例:
#   # 启用Google搜索 (使用FlareSolverr)
#   SEARCH_ENGINE_GOOGLE_ENABLED=true
#   docker-compose --profile all up -d
#
#   # 仅启用Bing和Baidu
#   SEARCH_ENGINE_GOOGLE_ENABLED=false
#   SEARCH_ENGINE_BING_ENABLED=true
#   SEARCH_ENGINE_BAIDU_ENABLED=true
#   SEARCH_ENGINE_SOGOU_ENABLED=false
#
# FlareSolverr独立启动示例:
#   # 即使Google未启用，也可以单独启动FlareSolverr进行测试
#   docker-compose --profile browser up -d flaresolverr
#
# =============================================================================
