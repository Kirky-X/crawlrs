# =============================================================================
# MinIO 环境变量配置
# =============================================================================
# 复制此文件为 .env 并根据需要修改配置

# MinIO 认证配置
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123

# MinIO 端口配置
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# =============================================================================
# 应用程序 S3 存储配置
# =============================================================================
# 将以下配置添加到主 .env 文件或 config/default.toml 中

# 存储类型设置为 s3
CRAWLRS__STORAGE__STORAGE_TYPE=s3

# S3 配置
CRAWLRS__STORAGE__S3_REGION=us-east-1
CRAWLRS__STORAGE__S3_BUCKET=crawlrs
CRAWLRS__STORAGE__S3_ACCESS_KEY=minioadmin
CRAWLRS__STORAGE__S3_SECRET_KEY=minioadmin123
CRAWLRS__STORAGE__S3_ENDPOINT=http://localhost:9000

# 或者在 config/default.toml 中配置:
# [storage]
# storage_type = "s3"
# s3_region = "us-east-1"
# s3_bucket = "crawlrs"
# s3_access_key = "minioadmin"
# s3_secret_key = "minioadmin123"
# s3_endpoint = "http://localhost:9000"