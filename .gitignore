# =============================================================================
# Crawlrs Project .gitignore
# =============================================================================
# Version: 1.0.0
# Updated: 2025-01-15
# Purpose: Comprehensive ignore rules for crawlrs project
# =============================================================================

# -----------------------------------------------------------------------------
# Section 1: Rust/Cargo Build Artifacts
# -----------------------------------------------------------------------------
# Cargo will have compiled files and executables
debug/
target/

# Remove Cargo.lock from gitignore if creating an executable
# More information: https://doc.rust-lang.org/cargo/guide/cargo-guide.html
# Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging info
*.pdb

# -----------------------------------------------------------------------------
# Section 2: IDE and Editor Files
# -----------------------------------------------------------------------------
# VSCode
.vscode/
*.swp
*.swo

# IntelliJ IDEA / JetBrains
.idea/
*.iml
*.ipr
*.iws

# Vim/Emacs
.*.swp
*~
.#*
\#*

# Apple
.DS_Store
AppleDouble
.LSOverride

# Windows
Thumbs.db
ehthumbs.db
Desktop.ini

# Trae
.trae/

# Claude AI
.claude/

# Shared folder
.shared/

# AGENTS files
AGENTS.md
openspec/AGENTS.md

# -----------------------------------------------------------------------------
# Section 3: Project-Specific Directories
# -----------------------------------------------------------------------------
# Temporary directories
temp/
logs/

# Application data directories
data/
storage/
storage-local/

# Test data
test-data/
tests/crate/

# OpenSpec documentation
openspec/

# -----------------------------------------------------------------------------
# Section 4: Environment and Configuration Files
# -----------------------------------------------------------------------------
# Local environment files (contain sensitive data)
*.env
*.env.local
*.env.*.local
!.env.example
!.env.test.example

# Test environment configuration (contains passwords/secrets)
config/test.env
config/test.toml

# Docker environment files
docker/.env
docker/.env.test
docker/.env.local

# -----------------------------------------------------------------------------
# Section 5: Docker and Container Artifacts
# -----------------------------------------------------------------------------
# Docker Compose files with sensitive data (passwords, secrets)
docker/docker-compose.test.yml
!docker/docker-compose.test.yml.example

# Dockerfile files that may contain project-specific configurations
docker/Dockerfile.test
!docker/Dockerfile.test.example

# Docker data volumes (should not be committed)
docker/data/*
!docker/data/.gitkeep

# Docker test results
docker/test-results/

# -----------------------------------------------------------------------------
# Section 6: Python
# -----------------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual environments
venv/
ENV/
env/
.venv/

# -----------------------------------------------------------------------------
# Section 7: Node.js / JavaScript
# -----------------------------------------------------------------------------
node_modules/
dist/
build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.lerna-cache/

# -----------------------------------------------------------------------------
# Section 8: Compiled and Binary Files
# -----------------------------------------------------------------------------
*.a
*.o
*.so
*.dylib
*.dll
*.exe
*.out
*.app
*.jar

# -----------------------------------------------------------------------------
# Section 9: Backup and Archive Files
# -----------------------------------------------------------------------------
*.tmp
*.temp
*.bak
*.backup
*.orig
*.rej
*.patch
*~

# -----------------------------------------------------------------------------
# Section 10: Cache Files
# -----------------------------------------------------------------------------
*.cache
*.rdb
.rustc/
cargo-lock.json.backup

# -----------------------------------------------------------------------------
# Section 11: Documentation Exclusions
# -----------------------------------------------------------------------------
# Uncomment if these docs should not be tracked
# docs/prd.md
# docs/task.md
# docs/tdd.md
# docs/test.md
# docs/uat.md

# -----------------------------------------------------------------------------
# Section 12: Cargo and Rust Specific
# -----------------------------------------------------------------------------
.cargo/
Cargo.lock  # Uncomment if binary, keep if library

# -----------------------------------------------------------------------------
# Section 13: Database Files
# -----------------------------------------------------------------------------
*.sqlite
*.sqlite3
*.db
*.sqlite-journal

# -----------------------------------------------------------------------------
# Section 14: Misc
# -----------------------------------------------------------------------------
*.pid
*.seed
*.pid.lock

# End of .gitignore
